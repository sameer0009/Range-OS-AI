[Unit]
Description=RangeOS AI Orchestration Service
PartOf=rangeos-core.target
After=rangeos-virt.target

[Service]
Type=simple
User=range-operator
WorkingDirectory=/opt/rangeos/services/orchestration-service
ExecStart=/usr/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8007
Restart=always
RestartSec=5
SyslogIdentifier=rangeos-orch

[Install]
WantedBy=rangeos-core.target
