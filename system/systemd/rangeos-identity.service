[Unit]
Description=RangeOS AI Identity Service
PartOf=rangeos-core.target
After=rangeos-core.target

[Service]
Type=simple
User=range-operator
WorkingDirectory=/opt/rangeos/services/identity-service
ExecStart=/usr/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=3
SyslogIdentifier=rangeos-identity

[Install]
WantedBy=rangeos-core.target
