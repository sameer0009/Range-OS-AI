#!/bin/bash
# RangeOS AI - Tactical Session Wrapper
# Orchestrates the transition from login to HUD

set -e

# 1. Environment Setup
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=KDE
export WAYLAND_DISPLAY=wayland-0

echo "[*] Initializing Tactical Forge Session..."

# 2. Perform Pre-Flight Intelligence Check
if /opt/rangeos/bin/rangeos-preflight --wait=15; then
    echo "[+] Health Check PASSED. Engaging Mission HUD..."
    systemctl --user isolate rangeos-session.target
else
    echo "[!] Health Check FAILED. Engaging Recovery Mode..."
    systemctl --user start rangeos-recovery.service
fi

echo "[+] Handing off supervision to systemd --user."
